{
  "autoUpdatesChannel": "latest",
  "theme": "dark",
  "awaySummaryEnabled": false,
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "PowerShell(*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm data/:*)",
      "Bash(rm -r data/:*)",
      "Edit(data/**)",
      "Write(data/**)",
      "Read(.env)",
      "Read(*.key)",
      "Bash(git push:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  }
}
