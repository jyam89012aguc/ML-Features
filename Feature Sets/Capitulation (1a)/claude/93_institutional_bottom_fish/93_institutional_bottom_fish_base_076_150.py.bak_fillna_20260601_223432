def ibf_150_full_composite_bottom_fish(new_positions: pd.Series,
                                        increased_positions: pd.Series,
                                        closed_positions: pd.Series,
                                        decreased_positions: pd.Series,
                                        inst_holders: pd.Series,
                                        inst_shares: pd.Series,
                                        inst_value: pd.Series,
                                        inst_pct: pd.Series,
                                        close: pd.Series) -> pd.Series:
    """Full composite bottom-fishing score: sum of z-scores of gross add, net add,
    share inflow, value inflow, pct inflow, all scaled by 3-yr drawdown depth."""
    gross = new_positions.fillna(0) + increased_positions.fillna(0)
    net = gross - closed_positions.fillna(0) - decreased_positions.fillna(0)
    s_in = inst_shares.fillna(method='ffill').diff(_TD_QTR).clip(lower=0)
    v_in = inst_value.fillna(method='ffill').diff(_TD_QTR).clip(lower=0)
    p_in = inst_pct.fillna(method='ffill').diff(_TD_QTR).clip(lower=0)
    z = (_zscore_rolling(gross, _TD_YEAR)
         + _zscore_rolling(net, _TD_YEAR)
         + _zscore_rolling(s_in, _TD_YEAR)
         + _zscore_rolling(v_in, _TD_YEAR)
         + _zscore_rolling(p_in, _TD_YEAR))
    dd = _drawdown_from_trailing_high(close, _TD_3Y)
    return z * dd


