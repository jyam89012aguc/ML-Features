"""
93_institutional_bottom_fish | SF3 Institutional Ownership — Accumulation at Lows (Features 076-200)

DOMAIN
------
Institutions ENTERING or ADDING positions while the stock is deep in a drawdown
("bottom fishing"). Covers new-position counts, increased-position counts, net
additions, share/value inflows, and accumulation conditioned on proximity to
multi-year price lows.

OUT OF SCOPE for this folder
-----------------------------
- Holder exits / declines           → folder 91
- Concentration / HHI shape         → folder 92
- Peer-relative breadth             → folder 94
- Forced-selling signals            → folder 95

QUARTERLY → DAILY ALIGNMENT CONTRACT
-------------------------------------
Sharadar SF3 13F ownership fields (new_positions, increased_positions,
closed_positions, decreased_positions, inst_holders, inst_shares, inst_value,
inst_pct) are reported quarterly and are **forward-filled** to a daily index
before being passed in.

`close` is a genuine daily price series used ONLY to characterise drawdown
depth / proximity to the trailing low.

Trading-day conventions
------------------------
1 quarter  = 63  trading days  (_TD_QTR)
2 quarters = 126 trading days  (_TD_2Q)
1 year     = 252 trading days  (_TD_YEAR)
2 years    = 504 trading days  (_TD_2Y)
3 years    = 756 trading days  (_TD_3Y)
"""

import numpy as np
import pandas as pd

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
_TD_YEAR = 252
_TD_2Y   = 504
_TD_3Y   = 756
_TD_QTR  = 63
_TD_2Q   = 126
_EPS     = 1e-9

# ---------------------------------------------------------------------------
# Utility helpers
# ---------------------------------------------------------------------------

def _align_quarterly_to_daily(series: pd.Series) -> pd.Series:
    """Forward-fill a quarterly snapshot series to a daily index (no-op if
    already ffilled by caller)."""
    return series


def _safe_div(num: pd.Series, den: pd.Series) -> pd.Series:
    return num / (den.replace(0, np.nan) + _EPS * (den == 0).astype(float))


def _safe_div_abs(num: pd.Series, den: pd.Series) -> pd.Series:
    return num / (den.abs().replace(0, np.nan) + _EPS * (den.abs() == 0).astype(float))


def _rolling_mean(s: pd.Series, w: int) -> pd.Series:
    return s.rolling(w, min_periods=1).mean()


def _rolling_std(s: pd.Series, w: int) -> pd.Series:
    return s.rolling(w, min_periods=2).std()


def _rolling_sum(s: pd.Series, w: int) -> pd.Series:
    return s.rolling(w, min_periods=1).sum()


def _rolling_min(s: pd.Series, w: int) -> pd.Series:
    return s.rolling(w, min_periods=1).min()


def _rolling_max(s: pd.Series, w: int) -> pd.Series:
    return s.rolling(w, min_periods=1).max()


def _rolling_median(s: pd.Series, w: int) -> pd.Series:
    return s.rolling(w, min_periods=1).median()


def _rolling_rank_pct(s: pd.Series, w: int) -> pd.Series:
    return s.rolling(w, min_periods=2).apply(
        lambda x: pd.Series(x).rank(pct=True).iloc[-1], raw=False
    )


def _zscore_rolling(s: pd.Series, w: int) -> pd.Series:
    mu = _rolling_mean(s, w)
    sd = _rolling_std(s, w).replace(0, np.nan)
    return (s - mu) / (sd + _EPS)


def _ewm_mean(s: pd.Series, span: int) -> pd.Series:
    return s.ewm(span=span, min_periods=1).mean()


def _proximity_to_trailing_low(close: pd.Series, window: int) -> pd.Series:
    """(close - trailing_low) / trailing_low  >=0; 0 = at the low."""
    trail_low = _rolling_min(close, window)
    return _safe_div(close - trail_low, trail_low)


def _drawdown_from_trailing_high(close: pd.Series, window: int) -> pd.Series:
    """(trailing_high - close) / trailing_high  >=0; 0 = at the high."""
    trail_high = _rolling_max(close, window)
    return _safe_div(trail_high - close, trail_high)


# ===========================================================================
# Features 076 – 150
# ===========================================================================

# --- Ownership-level momentum and acceleration -----------------------------

def ibf_076_inst_holders_qoq_change(inst_holders: pd.Series) -> pd.Series:
    """QoQ change in total institutional holder count."""
    return inst_holders.fillna(method='ffill').diff(_TD_QTR)


def ibf_077_inst_holders_2q_change(inst_holders: pd.Series) -> pd.Series:
    """2-quarter change in total institutional holder count."""
    return inst_holders.fillna(method='ffill').diff(_TD_2Q)


def ibf_078_inst_holders_qoq_pct(inst_holders: pd.Series) -> pd.Series:
    """QoQ % change in total holder count."""
    s = inst_holders.fillna(method='ffill')
    prev = s.shift(_TD_QTR)
    return _safe_div(s - prev, prev.abs() + _EPS)


def ibf_079_inst_holders_at_1y_low(inst_holders: pd.Series,
                                    close: pd.Series) -> pd.Series:
    """Positive QoQ holder-count change * 1-yr drawdown depth."""
    chg = inst_holders.fillna(method='ffill').diff(_TD_QTR).clip(lower=0)
    prox = _proximity_to_trailing_low(close, _TD_YEAR)
    return chg * (1 - prox).clip(0, 1)


def ibf_080_inst_holders_rolling_4q_max(inst_holders: pd.Series) -> pd.Series:
    """4-quarter trailing maximum of institutional holders."""
    return _rolling_max(inst_holders.fillna(method='ffill'), _TD_YEAR)


# --- Large-block accumulation proxies (value/shares per holder) -------------

def ibf_081_large_ticket_new_flag(inst_value: pd.Series,
                                   new_positions: pd.Series) -> pd.Series:
    """1 if avg value per new holder exceeds 1-yr 75th pctile, else 0."""
    ratio = _safe_div(inst_value.fillna(0), new_positions.replace(0, np.nan))
    thresh = ratio.rolling(_TD_YEAR, min_periods=1).quantile(0.75)
    return (ratio >= thresh).astype(float)


def ibf_082_large_block_inflow_1y_low(inst_value: pd.Series,
                                       new_positions: pd.Series,
                                       close: pd.Series) -> pd.Series:
    """Large-ticket flag * 1-yr drawdown depth."""
    flag = ibf_081_large_ticket_new_flag(inst_value, new_positions)
    dd = _drawdown_from_trailing_high(close, _TD_YEAR)
    return flag * dd


def ibf_083_value_per_holder_zscore_1y(inst_value: pd.Series,
                                        inst_holders: pd.Series) -> pd.Series:
    """Z-score of (value / holders) over 1-year window."""
    ratio = _safe_div(inst_value.fillna(0),
                      inst_holders.fillna(method='ffill').replace(0, np.nan))
    return _zscore_rolling(ratio, _TD_YEAR)


def ibf_084_shares_per_holder_zscore_1y(inst_shares: pd.Series,
                                         inst_holders: pd.Series) -> pd.Series:
    """Z-score of (shares / holders) over 1-year window."""
    ratio = _safe_div(inst_shares.fillna(0),
                      inst_holders.fillna(method='ffill').replace(0, np.nan))
    return _zscore_rolling(ratio, _TD_YEAR)


def ibf_085_value_per_holder_at_2y_low(inst_value: pd.Series,
                                        inst_holders: pd.Series,
                                        close: pd.Series) -> pd.Series:
    """Value/holder ratio * 2-yr drawdown depth."""
    ratio = _safe_div(inst_value.fillna(0),
                      inst_holders.fillna(method='ffill').replace(0, np.nan))
    dd = _drawdown_from_trailing_high(close, _TD_2Y)
    return ratio * dd


# --- Acceleration: quarter-over-quarter delta of QoQ changes ---------------

def ibf_086_new_pos_qoq_acceleration(new_positions: pd.Series) -> pd.Series:
    """QoQ change in new_positions minus its 1-quarter-prior QoQ change (acceleration)."""
    np_ = new_positions.fillna(0)
    d1 = np_ - np_.shift(_TD_QTR)
    return d1 - d1.shift(_TD_QTR)


def ibf_087_increased_pos_qoq_acceleration(increased_positions: pd.Series) -> pd.Series:
    """Acceleration of increased_positions QoQ changes."""
    ip = increased_positions.fillna(0)
    d1 = ip - ip.shift(_TD_QTR)
    return d1 - d1.shift(_TD_QTR)


def ibf_088_gross_add_qoq_acceleration(new_positions: pd.Series,
                                        increased_positions: pd.Series) -> pd.Series:
    """Acceleration of gross-additions QoQ changes."""
    gross = new_positions.fillna(0) + increased_positions.fillna(0)
    d1 = gross - gross.shift(_TD_QTR)
    return d1 - d1.shift(_TD_QTR)


def ibf_089_inst_shares_qoq_acceleration(inst_shares: pd.Series) -> pd.Series:
    """Acceleration of institutional share-count QoQ changes."""
    s = inst_shares.fillna(method='ffill')
    d1 = s - s.shift(_TD_QTR)
    return d1 - d1.shift(_TD_QTR)


def ibf_090_inst_value_qoq_acceleration(inst_value: pd.Series) -> pd.Series:
    """Acceleration of institutional value QoQ changes."""
    v = inst_value.fillna(method='ffill')
    d1 = v - v.shift(_TD_QTR)
    return d1 - d1.shift(_TD_QTR)


# --- Positive-only (inflow) slices -----------------------------------------

def ibf_091_new_pos_positive_only(new_positions: pd.Series) -> pd.Series:
    """New positions clipped to positive values only (0 when negative or zero)."""
    return new_positions.fillna(0).clip(lower=0)


def ibf_092_shares_inflow_only(inst_shares: pd.Series) -> pd.Series:
    """Positive QoQ share change only (inflow); negative changes become 0."""
    return inst_shares.fillna(method='ffill').diff(_TD_QTR).clip(lower=0)


def ibf_093_value_inflow_only(inst_value: pd.Series) -> pd.Series:
    """Positive QoQ value change only (inflow)."""
    return inst_value.fillna(method='ffill').diff(_TD_QTR).clip(lower=0)


def ibf_094_pct_inflow_only(inst_pct: pd.Series) -> pd.Series:
    """Positive QoQ pct-ownership change only."""
    return inst_pct.fillna(method='ffill').diff(_TD_QTR).clip(lower=0)


def ibf_095_shares_inflow_zscore_2y(inst_shares: pd.Series) -> pd.Series:
    """2-year z-score of positive-only share inflow."""
    inflow = inst_shares.fillna(method='ffill').diff(_TD_QTR).clip(lower=0)
    return _zscore_rolling(inflow, _TD_2Y)


# --- Accumulation rate relative to holder base -----------------------------

def ibf_096_new_pos_per_holder_qoq(new_positions: pd.Series,
                                    inst_holders: pd.Series) -> pd.Series:
    """New positions normalised by prev-quarter holder count."""
    prev_holders = inst_holders.fillna(method='ffill').shift(_TD_QTR)
    return _safe_div(new_positions.fillna(0), prev_holders.replace(0, np.nan))


def ibf_097_gross_add_per_holder_qoq(new_positions: pd.Series,
                                      increased_positions: pd.Series,
                                      inst_holders: pd.Series) -> pd.Series:
    """Gross additions normalised by prev-quarter holder count."""
    gross = new_positions.fillna(0) + increased_positions.fillna(0)
    prev_h = inst_holders.fillna(method='ffill').shift(_TD_QTR)
    return _safe_div(gross, prev_h.replace(0, np.nan))


def ibf_098_net_add_per_holder(new_positions: pd.Series,
                                increased_positions: pd.Series,
                                closed_positions: pd.Series,
                                decreased_positions: pd.Series,
                                inst_holders: pd.Series) -> pd.Series:
    """Net additions / total holders."""
    net = (new_positions.fillna(0) + increased_positions.fillna(0)
           - closed_positions.fillna(0) - decreased_positions.fillna(0))
    return _safe_div(net, inst_holders.fillna(method='ffill').replace(0, np.nan))


def ibf_099_new_pos_holder_ratio_zscore(new_positions: pd.Series,
                                         inst_holders: pd.Series) -> pd.Series:
    """1-year z-score of (new_positions / inst_holders)."""
    ratio = _safe_div(new_positions.fillna(0),
                      inst_holders.fillna(method='ffill').replace(0, np.nan))
    return _zscore_rolling(ratio, _TD_YEAR)


def ibf_100_gross_add_holder_ratio_at_1y_low(new_positions: pd.Series,
                                              increased_positions: pd.Series,
                                              inst_holders: pd.Series,
                                              close: pd.Series) -> pd.Series:
    """(gross_add / holders) * 1-yr drawdown depth."""
    gross = new_positions.fillna(0) + increased_positions.fillna(0)
    ratio = _safe_div(gross, inst_holders.fillna(method='ffill').replace(0, np.nan))
    dd = _drawdown_from_trailing_high(close, _TD_YEAR)
    return ratio * dd


# --- Rolling EWM and trend signals -----------------------------------------

def ibf_101_new_pos_ewm_vs_sma_1y(new_positions: pd.Series) -> pd.Series:
    """EWM(1Q) minus 1-year SMA of new_positions (short-term vs long-term momentum)."""
    np_ = new_positions.fillna(0)
    return _ewm_mean(np_, _TD_QTR) - _rolling_mean(np_, _TD_YEAR)


def ibf_102_gross_add_ewm_vs_sma_2y(new_positions: pd.Series,
                                      increased_positions: pd.Series) -> pd.Series:
    """EWM(2Q) minus 2-year SMA of gross additions."""
    gross = new_positions.fillna(0) + increased_positions.fillna(0)
    return _ewm_mean(gross, _TD_2Q) - _rolling_mean(gross, _TD_2Y)


def ibf_103_inst_shares_ewm_vs_sma_1y(inst_shares: pd.Series) -> pd.Series:
    """EWM(1Q) minus 1-year SMA of institutional shares."""
    s = inst_shares.fillna(method='ffill').fillna(0)
    return _ewm_mean(s, _TD_QTR) - _rolling_mean(s, _TD_YEAR)


def ibf_104_inst_value_ewm_vs_sma_1y(inst_value: pd.Series) -> pd.Series:
    """EWM(1Q) minus 1-year SMA of institutional value."""
    v = inst_value.fillna(method='ffill').fillna(0)
    return _ewm_mean(v, _TD_QTR) - _rolling_mean(v, _TD_YEAR)


def ibf_105_net_add_ewm_signal(new_positions: pd.Series,
                                increased_positions: pd.Series,
                                closed_positions: pd.Series,
                                decreased_positions: pd.Series) -> pd.Series:
    """EWM(1Q) of net additions."""
    net = (new_positions.fillna(0) + increased_positions.fillna(0)
           - closed_positions.fillna(0) - decreased_positions.fillna(0))
    return _ewm_mean(net, _TD_QTR)


# --- Drawdown-conditioned rolling sums -------------------------------------

def ibf_106_new_pos_sum_4q_at_2y_low(new_positions: pd.Series,
                                      close: pd.Series) -> pd.Series:
    """4-quarter rolling sum of new_positions, masked to days near 2-yr low (within 15%)."""
    prox = _proximity_to_trailing_low(close, _TD_2Y)
    masked = new_positions.fillna(0) * (prox <= 0.15).astype(float)
    return _rolling_sum(masked, _TD_YEAR)


def ibf_107_gross_add_sum_4q_at_3y_low(new_positions: pd.Series,
                                        increased_positions: pd.Series,
                                        close: pd.Series) -> pd.Series:
    """4-quarter rolling sum of gross additions masked to within 20% of 3-yr low."""
    gross = new_positions.fillna(0) + increased_positions.fillna(0)
    prox = _proximity_to_trailing_low(close, _TD_3Y)
    masked = gross * (prox <= 0.20).astype(float)
    return _rolling_sum(masked, _TD_YEAR)


def ibf_108_value_inflow_sum_2y_at_3y_low(inst_value: pd.Series,
                                            close: pd.Series) -> pd.Series:
    """2-year rolling sum of value inflows masked to within 25% of 3-yr low."""
    inflow = inst_value.fillna(method='ffill').diff(_TD_QTR).clip(lower=0)
    prox = _proximity_to_trailing_low(close, _TD_3Y)
    masked = inflow * (prox <= 0.25).astype(float)
    return _rolling_sum(masked, _TD_2Y)


def ibf_109_shares_inflow_sum_2y_at_2y_low(inst_shares: pd.Series,
                                             close: pd.Series) -> pd.Series:
    """2-year rolling sum of share inflows near 2-yr low."""
    inflow = inst_shares.fillna(method='ffill').diff(_TD_QTR).clip(lower=0)
    prox = _proximity_to_trailing_low(close, _TD_2Y)
    masked = inflow * (prox <= 0.15).astype(float)
    return _rolling_sum(masked, _TD_2Y)


def ibf_110_net_add_sum_4q_at_1y_low(new_positions: pd.Series,
                                      increased_positions: pd.Series,
                                      closed_positions: pd.Series,
                                      decreased_positions: pd.Series,
                                      close: pd.Series) -> pd.Series:
    """4-quarter sum of net additions when within 10% of 1-yr low."""
    net = (new_positions.fillna(0) + increased_positions.fillna(0)
           - closed_positions.fillna(0) - decreased_positions.fillna(0))
    prox = _proximity_to_trailing_low(close, _TD_YEAR)
    masked = net * (prox <= 0.10).astype(float)
    return _rolling_sum(masked, _TD_YEAR)


# --- Breadth of accumulation (proportion of holders buying) ----------------

def ibf_111_new_to_total_ratio(new_positions: pd.Series,
                                inst_holders: pd.Series) -> pd.Series:
    """new_positions / inst_holders — entry rate among current holders."""
    return _safe_div(new_positions.fillna(0),
                     inst_holders.fillna(method='ffill').replace(0, np.nan))


def ibf_112_increased_to_total_ratio(increased_positions: pd.Series,
                                      inst_holders: pd.Series) -> pd.Series:
    """increased_positions / inst_holders."""
    return _safe_div(increased_positions.fillna(0),
                     inst_holders.fillna(method='ffill').replace(0, np.nan))


def ibf_113_buyer_breadth_index(new_positions: pd.Series,
                                 increased_positions: pd.Series,
                                 inst_holders: pd.Series) -> pd.Series:
    """(new + increased) / inst_holders — fraction of holder universe actively buying."""
    gross = new_positions.fillna(0) + increased_positions.fillna(0)
    return _safe_div(gross, inst_holders.fillna(method='ffill').replace(0, np.nan))


def ibf_114_buyer_breadth_at_2y_low(new_positions: pd.Series,
                                     increased_positions: pd.Series,
                                     inst_holders: pd.Series,
                                     close: pd.Series) -> pd.Series:
    """Buyer breadth * 2-yr drawdown depth."""
    breadth = ibf_113_buyer_breadth_index(new_positions, increased_positions, inst_holders)
    dd = _drawdown_from_trailing_high(close, _TD_2Y)
    return breadth * dd


def ibf_115_buyer_breadth_zscore_2y(new_positions: pd.Series,
                                     increased_positions: pd.Series,
                                     inst_holders: pd.Series) -> pd.Series:
    """2-year z-score of buyer breadth."""
    breadth = ibf_113_buyer_breadth_index(new_positions, increased_positions, inst_holders)
    return _zscore_rolling(breadth, _TD_2Y)


# --- Multi-quarter running totals of accumulation ----------------------------

def ibf_116_new_pos_cumsum_2y(new_positions: pd.Series) -> pd.Series:
    """2-year rolling cumulative sum of new positions."""
    return _rolling_sum(new_positions.fillna(0), _TD_2Y)


def ibf_117_gross_add_cumsum_3y(new_positions: pd.Series,
                                  increased_positions: pd.Series) -> pd.Series:
    """3-year rolling cumulative sum of gross additions."""
    gross = new_positions.fillna(0) + increased_positions.fillna(0)
    return _rolling_sum(gross, _TD_3Y)


def ibf_118_net_add_cumsum_2y(new_positions: pd.Series,
                               increased_positions: pd.Series,
                               closed_positions: pd.Series,
                               decreased_positions: pd.Series) -> pd.Series:
    """2-year rolling cumulative sum of net additions."""
    net = (new_positions.fillna(0) + increased_positions.fillna(0)
           - closed_positions.fillna(0) - decreased_positions.fillna(0))
    return _rolling_sum(net, _TD_2Y)


def ibf_119_inst_shares_3y_range_pct(inst_shares: pd.Series) -> pd.Series:
    """Current shares relative to 3-yr range: (s - min) / (max - min)."""
    s = inst_shares.fillna(method='ffill')
    lo = _rolling_min(s, _TD_3Y)
    hi = _rolling_max(s, _TD_3Y)
    return _safe_div(s - lo, hi - lo + _EPS)


def ibf_120_inst_value_2y_range_pct(inst_value: pd.Series) -> pd.Series:
    """Current value relative to 2-yr range: (v - min) / (max - min)."""
    v = inst_value.fillna(method='ffill')
    lo = _rolling_min(v, _TD_2Y)
    hi = _rolling_max(v, _TD_2Y)
    return _safe_div(v - lo, hi - lo + _EPS)


# --- Relative change signals over various lags ------------------------------

def ibf_121_new_pos_vs_prior_3q(new_positions: pd.Series) -> pd.Series:
    """new_positions vs its value 3 quarters ago."""
    np_ = new_positions.fillna(0)
    return np_ - np_.shift(_TD_QTR * 3)


def ibf_122_gross_add_vs_prior_4q(new_positions: pd.Series,
                                    increased_positions: pd.Series) -> pd.Series:
    """Gross additions vs value 4 quarters ago."""
    gross = new_positions.fillna(0) + increased_positions.fillna(0)
    return gross - gross.shift(_TD_YEAR)


def ibf_123_inst_pct_vs_prior_4q(inst_pct: pd.Series) -> pd.Series:
    """inst_pct minus its value 4 quarters ago."""
    s = inst_pct.fillna(method='ffill')
    return s - s.shift(_TD_YEAR)


def ibf_124_inst_shares_vs_prior_4q(inst_shares: pd.Series) -> pd.Series:
    """Institutional shares minus their value 4 quarters ago."""
    s = inst_shares.fillna(method='ffill')
    return s - s.shift(_TD_YEAR)


def ibf_125_inst_value_vs_prior_2q(inst_value: pd.Series) -> pd.Series:
    """Institutional value minus value 2 quarters ago."""
    v = inst_value.fillna(method='ffill')
    return v - v.shift(_TD_2Q)


# --- Composite interaction terms -------------------------------------------

def ibf_126_accum_intensity_score(new_positions: pd.Series,
                                   increased_positions: pd.Series,
                                   inst_shares: pd.Series,
                                   inst_value: pd.Series) -> pd.Series:
    """Composite: z-score of gross_add + z-score of share_inflow + z-score of value_inflow."""
    gross = new_positions.fillna(0) + increased_positions.fillna(0)
    s_in = inst_shares.fillna(method='ffill').diff(_TD_QTR).clip(lower=0)
    v_in = inst_value.fillna(method='ffill').diff(_TD_QTR).clip(lower=0)
    return (_zscore_rolling(gross, _TD_YEAR)
            + _zscore_rolling(s_in, _TD_YEAR)
            + _zscore_rolling(v_in, _TD_YEAR))


def ibf_127_accum_intensity_at_3y_low(new_positions: pd.Series,
                                       increased_positions: pd.Series,
                                       inst_shares: pd.Series,
                                       inst_value: pd.Series,
                                       close: pd.Series) -> pd.Series:
    """Accumulation intensity score * 3-yr drawdown depth."""
    intensity = ibf_126_accum_intensity_score(
        new_positions, increased_positions, inst_shares, inst_value
    )
    dd = _drawdown_from_trailing_high(close, _TD_3Y)
    return intensity * dd


def ibf_128_add_ratio_rolling_2q(new_positions: pd.Series,
                                   increased_positions: pd.Series,
                                   closed_positions: pd.Series,
                                   decreased_positions: pd.Series) -> pd.Series:
    """2-quarter rolling mean of the add-to-exit ratio."""
    adds = new_positions.fillna(0) + increased_positions.fillna(0)
    exits = closed_positions.fillna(0) + decreased_positions.fillna(0)
    ratio = _safe_div(adds, exits + _EPS)
    return _rolling_mean(ratio, _TD_2Q)


def ibf_129_add_ratio_rolling_4q(new_positions: pd.Series,
                                   increased_positions: pd.Series,
                                   closed_positions: pd.Series,
                                   decreased_positions: pd.Series) -> pd.Series:
    """4-quarter rolling mean of the add-to-exit ratio."""
    adds = new_positions.fillna(0) + increased_positions.fillna(0)
    exits = closed_positions.fillna(0) + decreased_positions.fillna(0)
    ratio = _safe_div(adds, exits + _EPS)
    return _rolling_mean(ratio, _TD_YEAR)


def ibf_130_add_ratio_zscore_2y(new_positions: pd.Series,
                                  increased_positions: pd.Series,
                                  closed_positions: pd.Series,
                                  decreased_positions: pd.Series) -> pd.Series:
    """2-year z-score of add-to-exit ratio."""
