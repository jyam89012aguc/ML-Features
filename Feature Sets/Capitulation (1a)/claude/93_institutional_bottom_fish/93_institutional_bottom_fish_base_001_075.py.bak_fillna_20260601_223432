def ibf_156_inst_pct_3y_range_pct(inst_pct: pd.Series) -> pd.Series:
    """inst_pct relative to its 3-yr range: (p - min) / (max - min)."""
    s = inst_pct.fillna(method='ffill')
    lo = _rolling_min(s, _TD_3Y)
    hi = _rolling_max(s, _TD_3Y)
