def f28pd_f28_price_volume_divergence_xor_streak_40d_jerk_v004_signal(closeadj, volume):
    k = 10
    sp = np.sign(closeadj.diff(1)); sv = np.sign(volume.diff(1))
    bit = (sp != sv).astype(float).where(~sp.isna() & ~sv.isna())
    def _consec(x):
        c = 0
        for v in x[::-1]:
            if v > 0.5: c += 1
            else: break
        return float(c)
    return _J(bit.rolling(40, min_periods=40).apply(_consec, raw=True), k)


